// Example Tier 2/3 handler for a ModuLab module (Deno runtime).
//
// Runs in its own Deno Worker (one per module), isolated from Core and
// other modules. Permissions are restricted by Core based on your
// manifest.yaml declarations: --allow-net only hosts listed in egress_allowlist,
// --allow-read/write only this module's storage directory, --cached-only means
// no runtime fetching of dependencies (vendor them, see README).
//
// You do NOT implement your own authentication. Core calls your handler
// with a typed, already-verified auth context - trust it, nothing else.

export interface ModuleAuthContext {
userId: string;
userEmail: string;
userName: string;
roles: string[];
}

export interface HandlerRequest {
method: "GET" | "POST" | "PATCH" | "DELETE";
path: string;
body?: unknown;
auth: ModuleAuthContext;
// Scoped database client, can only touch this module's own PostgreSQL
// schema (module_{name}), enforced by a dedicated role + search_path.
// This is schema-level isolation, not row-level security (RLS) - RLS is
// not currently used for module data.
db: ModuleDbClient;
}

// Your module has no Core-provided mechanism for typed/encrypted external
// credentials (e.g. a third-party API key). If your handler needs one,
// store it yourself: e.g. a settings table in your own module_{name}
// schema, written through your own tier 2/3 admin UI. Never hardcode
// secrets into your handler code or manifest.yaml.

export interface HandlerResponse {
status: number;
body: unknown;
}

export interface ModuleDbClient {
query<T = unknown>(sql: string, params?: unknown[]): Promise<T[]>;
}

export default async function handler(req: HandlerRequest): Promise<HandlerResponse> {
switch (`${req.method} ${req.path}`) {
case "GET /items": {
const rows = await req.db.query("SELECT id, title FROM items ORDER BY created_at DESC");
return { status: 200, body: rows };
}

case "POST /items": {
const { title } = req.body as { title: string };
const [row] = await req.db.query(
"INSERT INTO items (title, created_by) VALUES ($1, $2) RETURNING id, title",
[title, req.auth.userId],
);
return { status: 201, body: row };
}

default:
return { status: 404, body: { error: "not found" } };
}
}
